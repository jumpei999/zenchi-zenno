{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zenchi-zenno.dev/schemas/entity.base.schema.json",
  "title": "EntityBase",
  "description": "Draft base schema for zenchi-zenno canonical knowledge entities. Phase 0 — not validated or code-generated.",
  "type": "object",
  "required": [
    "id",
    "workspace_id",
    "type",
    "title",
    "status",
    "confirmation_state",
    "evidence_refs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "ULID or UUID"
    },
    "workspace_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "Decision",
        "Idea",
        "Project",
        "Person",
        "Interest",
        "Learning",
        "Artifact",
        "Event"
      ]
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "sensitivity": {
      "type": "string",
      "enum": ["private", "shareable", "restricted"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confirmation_state": {
      "type": "string",
      "enum": ["hypothesized", "confirmed", "disputed", "archived"]
    },
    "valid_from": {
      "type": "string",
      "format": "date-time"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "provenance": {
      "type": "object",
      "properties": {
        "extractor": { "type": "string" },
        "model": { "type": "string" },
        "prompt_version": { "type": "string" },
        "connector_version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "attributes": {
      "type": "object",
      "description": "Type-specific payload. See docs/knowledge-model.md"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
